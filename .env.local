# Local development against Postgres from docker-compose (db service).
# Matches api service in docker-compose.yml; DB_HOST is localhost for go run on the host.

APP_ENV=development
APP_PORT=8000
DB_TYPE=postgres
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
APP_DB_USER=postgres
APP_DB_PASS=postgres
APP_DB_NAME=test

# Docker Compose db credentials (for local stack parity)
POSTGRES_USER=root
POSTGRES_PASSWORD=password
